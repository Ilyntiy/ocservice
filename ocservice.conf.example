# ocservice.conf — ocserv-tools configuration
# Generated by install.sh. Edit manually if needed.
# Place this file in the same directory as the scripts (e.g. ~/bin/).

# =============================================================================
# Paths — set manually
# =============================================================================

# ocserv installation prefix (the directory you passed to --prefix during build)
OCSERV_PREFIX=/home/user/ocserv

# Path to your easy-rsa directory
EASYRSA_DIR=/home/user/easy-rsa

# Directory where generated .p12 client files will be stored
VPN_CLIENTS_DIR=/home/user/vpn-clients

# =============================================================================
# Authentication mode
# =============================================================================

# Controls which user creation commands are available.
# Must match what is actually enabled in ocserv.conf.
#
# cert  — certificate auth only (auth = "certificate")
# plain — password auth only   (auth = "plain[...]")
# both  — both methods enabled  (auth = "plain[...]" + enable-auth = "certificate")
#
AUTH_MODE=both

# =============================================================================
# Paths — parsed from ocserv.conf by install.sh
# Do not edit manually unless you know what you are doing.
# To update these paths, re-run install.sh or edit ocserv.conf first.
# =============================================================================

# Path to the ocpasswd file (pwdfile directive in ocserv.conf)
# Required only if AUTH_MODE=plain or AUTH_MODE=both. Leave as-is if AUTH_MODE=cert.
USER_FILE=/home/user/ocserv/etc/ocpasswd

# Path to config-per-user directory (config-per-user directive in ocserv.conf)
CONFIG_PER_USER=/home/user/ocserv/etc/config-per-user

# Path to ocserv.conf itself (used by ocservice to open it in editor)
OCSERV_CONF=/home/user/ocserv/etc/ocserv.conf

# =============================================================================
# Derived paths — adjust only if your directory layout differs from standard
# =============================================================================

USER_HISTORY=$OCSERV_PREFIX/user-history.log
OCCTL=$OCSERV_PREFIX/bin/occtl
OCPASSWD=$OCSERV_PREFIX/bin/ocpasswd

# =============================================================================
# Security
# =============================================================================

# Length of auto-generated passwords (for both cert and login users).
PASSWORD_LENGTH=20

# =============================================================================
# Server identity
# =============================================================================

# Display name of this server.
# Used as the CA name in .p12 certificates and in the main menu header.
SERVER_NAME=MyVPN

# =============================================================================
# Server certificate
# =============================================================================

# Path to the server TLS certificate file (server-cert directive in ocserv.conf).
# Used to display certificate expiry with color indicators in the main menu.
# Parsed automatically from ocserv.conf by install.sh.
# If the main menu shows n/a, check this value and re-run install.sh to fix it.
SERVER_CERT=/path/to/server-cert.pem

# =============================================================================
# Username pool
# =============================================================================

# Set to "yes" to enable the name pool feature.
# When enabled, gen-client and gen-login will offer a choice between picking
# a name from the pool or entering one manually.
# Set to "no" to always prompt for manual entry.
NAMES_ENABLED=yes

# Path to the file containing available usernames, one per line.
# Lines starting with # and empty lines are ignored.
# Add new names at any time — no restart needed.
NAMES_FILE="$(dirname "$(realpath "$0")")/names.txt"

# Path to the file where issued pool names are recorded.
# Managed automatically by gen-client and gen-login. Do not edit manually.
NAMES_USED_FILE="$(dirname "$(realpath "$0")")/names_used.txt"

# =============================================================================
# Certificate cache
# =============================================================================

# Path to the certificate dates cache file.
# Stores issue and expiry dates for certificate users to avoid reading
# each .crt file on every User Management Center open.
# Managed automatically by gen-client and user-center.
# If you create certificates outside of ocservice, run
# 'r — Rebuild cache' in User Management Center to update it.
CERT_CACHE_FILE="$(dirname "$(realpath "$0")")/cert_cache"

# =============================================================================
# Output template — shown to the client after user creation
# Edit these to match what you want to send to each new user.
# =============================================================================

# VPN gateway URL. Set automatically by install.sh based on server address
# and camouflage settings parsed from ocserv.conf.
# Format with camouflage: https://your-domain-or-ip/?camouflage-secret
# Format without:         https://your-domain-or-ip/
# Using IP instead of domain is also valid: https://1.2.3.4/?secret
SERVER_URL=https://vpn.example.com/

# Link to your documentation, onboarding guide, or Telegram channel.
DOCS_URL=https://t.me/yourchannel
