#!/bin/bash

# gen-client — create a new certificate-based VPN user
# Generates an easy-rsa client certificate and exports it as a .p12 file.
# Part of ocservice — https://github.com/Ilyntiy/ocservice

# =============================================================================
# Load config
# =============================================================================

CONFIG="$(dirname "$(realpath "$0")")/ocservice.conf"
if [[ ! -f "$CONFIG" ]]; then
  echo "Error: config file not found: $CONFIG"
  echo "Run install.sh first or create ocservice.conf manually."
  exit 1
fi
source "$CONFIG"

LIB="$(dirname "$(realpath "$0")")/ocnames"
if [[ ! -f "$LIB" ]]; then
  echo "Error: ocnames not found: $LIB"
  exit 1
fi
source "$LIB"

mkdir -p "$VPN_CLIENTS_DIR" "$CONFIG_PER_USER"

# =============================================================================
# Username
# =============================================================================

pick_username

# Guard against duplicate certificate (belt-and-suspenders)
if [[ -f "$EASYRSA_DIR/pki/issued/$USERNAME.crt" ]]; then
  echo "Error: certificate for '$USERNAME' already exists."
  exit 1
fi

# =============================================================================
# Certificate validity
# =============================================================================

while true; do
  read -rp "Certificate validity in days: " CERT_DAYS
  CERT_DAYS=${CERT_DAYS:-365}
  if [[ ! "$CERT_DAYS" =~ ^[0-9]+$ ]] || (( CERT_DAYS < 1 )); then
    echo "Error: enter a positive number of days."
  else
    break
  fi
done

# =============================================================================
# Max simultaneous connections
# =============================================================================

while true; do
  read -rp "Max simultaneous connections (0 = unlimited): " MAX_CONN
  MAX_CONN=${MAX_CONN:-0}
  if [[ ! "$MAX_CONN" =~ ^[0-9]+$ ]]; then
    echo "Error: enter a number (0 = unlimited)."
  else
    break
  fi
done

# =============================================================================
# Generate certificate
# =============================================================================

echo "Generating certificate..."
cd "$EASYRSA_DIR" || { echo "Error: easy-rsa directory not found: $EASYRSA_DIR"; exit 1; }

export EASYRSA_CERT_EXPIRE=$CERT_DAYS
./easyrsa build-client-full "$USERNAME" nopass || {
  echo "Error: certificate generation failed."
  exit 1
}

# =============================================================================
# Export .p12
# =============================================================================

PASSWORD=$(tr -dc A-Za-z0-9 </dev/urandom | head -c $PASSWORD_LENGTH)

openssl pkcs12 -export \
  -in pki/issued/"$USERNAME".crt \
  -inkey pki/private/"$USERNAME".key \
  -name "$USERNAME" \
  -certfile pki/ca.crt \
  -caname "$SERVER_NAME" \
  -out "$VPN_CLIENTS_DIR/$USERNAME.p12" \
  -passout pass:"$PASSWORD" \
  -macalg sha1 \
  --legacy || {
  echo "Error: .p12 export failed."
  exit 1
}

# Write config-per-user only after successful certificate creation
echo "max-same-clients = $MAX_CONN" > "$CONFIG_PER_USER/$USERNAME"

# =============================================================================
# Read certificate dates
# =============================================================================

START=$(openssl x509 -in "$EASYRSA_DIR/pki/issued/$USERNAME.crt" -noout -startdate | cut -d= -f2)
END=$(openssl x509   -in "$EASYRSA_DIR/pki/issued/$USERNAME.crt" -noout -enddate   | cut -d= -f2)

# =============================================================================
# Write to history log
# =============================================================================

echo "[cert-created] $(date '+%Y-%m-%d %H:%M') | $USERNAME | $START -> $END" >> "$USER_HISTORY"

# =============================================================================
# OUTPUT TEMPLATE — edit this block to customize what is shown / sent to users
# =============================================================================

echo
echo "================================================"
echo "  Username:             $USERNAME"
echo "  Certificate password: $PASSWORD"
echo "  Max connections:      $MAX_CONN" "(0 = unlimited)"
echo "  Valid for:            $CERT_DAYS days"
echo "  Certificate file:     $VPN_CLIENTS_DIR/$USERNAME.p12"
echo "  Gateway:              $SERVER_URL"
[[ -n "$DOCS_URL" ]] && echo "  Docs / channel:       $DOCS_URL"
echo "================================================"
echo

read -rp "Press Enter to return to menu..."
